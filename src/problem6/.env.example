PORT=8002

# Logs: default is JSON when NODE_ENV=production (Datadog / log drivers on stdout).
# Locally (e.g. npm run dev) uses readable console unless you set:
#   LOG_FORMAT=json
# or force console in prod:
#   LOG_FORMAT=console
# LOG_FORMAT=

DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=scoreboard

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

JWT_SECRET=super-secret-change-me

# Socket.IO CORS: `*` (dev) or comma-separated origins
SOCKET_CORS_ORIGIN=*

# Multi-instance WebSocket (extra Redis pub/sub connections)
SOCKET_IO_REDIS_ADAPTER=false

# Redis-backed rate limits on POST /api/scoreboard/update (per IP + per JWT sub, ~60s window)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_IP_MAX=300
RATE_LIMIT_SUB_MAX=60

# --- Datadog (optional; Agent holds DD_API_KEY) ---
# DD_TRACE_ENABLED=false
# DD_ENV=development
# DD_SERVICE=problem6-scoreboard
# DD_VERSION=local
# DD_AGENT_HOST=localhost
# DD_TRACE_AGENT_PORT=8126
# DD_LOGS_INJECTION=true
