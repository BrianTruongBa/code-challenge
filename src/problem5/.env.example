PORT=8001

# MySQL
# Local install: DB_HOST=localhost DB_PORT=3306 (or your server port).
# This folder’s docker-compose.yml maps MySQL to host port 3307 → use DB_PORT=3307 when Node runs on the host.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=problem5

# Optional: base URL for black-box tests (`tests/`, `npm test`)
# PROBLEM5_BASE_URL=http://127.0.0.1:8001
